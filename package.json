{
  "name": "nexus-emu",
  "version": "1.0.0",
  "description": "Nexus Emulator - Plataforma de jogos",
  "main": "src/main/index.js",
  "scripts": {
    "start": "concurrently \"webpack serve --mode development\" \"cross-env NODE_ENV=development electron .\"",
    "build": "webpack --mode production",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.nexus.emu",
    "productName": "Nexus Emu",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
  "target": "nsis",
  "icon": "public/logo.ico"
},
"nsis": {
  "oneClick": false,
  "allowToChangeInstallationDirectory": true,
  "installerIcon": "public/logo.ico",
  "installerHeaderIcon": "public/logo.ico",
  "createDesktopShortcut": true,
  "createStartMenuShortcut": true
}
  },
  "keywords": [],
  "author": "Nexus",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "axios": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "babel-loader": "^9.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "html-webpack-plugin": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^5.0.0"
  }
}